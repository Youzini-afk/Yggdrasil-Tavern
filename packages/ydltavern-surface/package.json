{
  "name": "@ydltavern/surface",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "YdlTavern surface package: reusable React components and surface manifests for Yggdrasil-hosted Tavern UI. Not an app shell.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest": "./surface.manifest.json",
    "./styles/surface.css": "./dist/styles/surface.css",
    "./styles/mobile.css": "./dist/styles/mobile.css",
    "./fixtures": {
      "types": "./dist/fixtures/sample-chat.d.ts",
      "default": "./dist/fixtures/sample-chat.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "surface.manifest.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc && node scripts/copy-assets.mjs && vite build",
    "build:bundle": "vite build",
    "prepare": "npm run build",
    "test": "tsx --test test/*.test.ts test/*.test.tsx test/**/*.test.ts test/**/*.test.tsx",
    "bench": "node bench/index.bench.mjs"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@ydltavern/engine-core": "file:../ydltavern-engine-core",
    "@ydltavern/extensions": "file:../ydltavern-extensions",
    "@ydltavern/importers": "file:../ydltavern-importers",
    "@ydltavern/st-compat": "file:../ydltavern-st-compat",
    "@ydltavern/types": "file:../ydltavern-types",
    "dompurify": "^3.4.5",
    "react-virtuoso": "^4.10.0",
    "showdown": "^2.1.0"
  },
  "devDependencies": {
    "@fontsource/noto-sans": "5.2.10",
    "@fontsource/noto-sans-mono": "5.2.10",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/showdown": "^2.0.6",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tinybench": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^5"
  }
}
